<?xml version="1.0" encoding="UTF-8"?>

<schemalist>

    <schema path="/org/gnome/shell/extensions/tasks-in-panel/" id="org.gnome.shell.extensions.tasks-in-panel">

        <key type="b" name="light-style">
            <default>true</default>
            <summary>Light style mode</summary>
        </key>

        <key type="b" name="yaru-panel">
            <default>true</default>
            <summary>Normal-weigthed fonts</summary>
        </key>

        <key type="b" name="accent-panel">
            <default>false</default>
            <summary>Use accent color</summary>
        </key>

        <key type="b" name="use-background-color">
            <default>false</default>
            <summary>Custom background color</summary>
        </key>

        <key name="background-color" type="s">
            <default>"rgba(0,0,0,1)"</default>
            <summary>Custom background color</summary>
        </key>

        <key type="b" name="scroll-panel">
            <default>true</default>
            <summary>Scroll on panel to change workspace</summary>
        </key>

        <key type="b" name="show-power-profile">
            <default>true</default>
            <summary>Show power profile indicator</summary>
        </key>

        <key type="b" name="show-user-id">
            <default>true</default>
            <summary>Show user name</summary>
        </key>

        <key type="b" name="show-show-desktop">
            <default>true</default>
            <summary>Show show desktop button</summary>
        </key>

        <key type="b" name="move-date">
            <default>true</default>
            <summary>Move date menu button to the right</summary>
        </key>

        <key type="b" name="show-activities">
            <default>false</default>
            <summary>Show activities indicator</summary>
        </key>

        <key type="b" name="show-workspaces-bar">
            <default>true</default>
            <summary>Show workspaces bar</summary>
        </key>

        <key type="b" name="show-plus-minus">
            <default>true</default>
            <summary>Show +/- to add/remove workspace</summary>
        </key>

        <key type="b" name="show-favorites-menu">
            <default>true</default>
            <summary>Show favorites menu button</summary>
        </key>

        <key type="b" name="show-recent-apps-menu">
            <default>true</default>
            <summary>Show recent applications menu button</summary>
        </key>

        <key type="i" name="recent-apps-list-length">
            <default>8</default>
            <summary>Recent applications list maximum length</summary>
        </key>

        <key type="b" name="center-tasks">
            <default>false</default>
            <summary>Move tasks to the center</summary>
        </key>

        <key type="b" name="show-window-icon">
            <default>true</default>
            <summary>Show window icon inside task button</summary>
        </key>

        <key type="b" name="show-window-title">
            <default>true</default>
            <summary>Show window title inside task button</summary>
        </key>

        <key type="b" name="show-window-app">
            <default>false</default>
            <summary>Show application name inside task button</summary>
        </key>

        <key type="b" name="show-active-workspace">
            <default>true</default>
            <summary>Show windows on active workspace only</summary>
        </key>

        <key type="b" name="show-focused-window">
            <default>false</default>
            <summary>Show task for focused window only</summary>
        </key>

        <key type="b" name="group-windows">
            <default>false</default>
            <summary>Group windows by app</summary>
        </key>

        <key type="b" name="hover-raise-window">
            <default>true</default>
            <summary>Raise window on task hover</summary>
        </key>

        <key type="i" name="hover-delay">
            <default>300</default>
            <summary>Raise window on hover delay</summary>
        </key>

        <key type="b" name="undecorated-task-buttons">
            <default>false</default>
            <summary>Undecorated task buttons</summary>
        </key>

        <key type="b" name="desaturate-icon">
            <default>false</default>
            <summary>Monochrome icon</summary>
        </key>

        <key type="i" name="button-width">
            <default>256</default>
            <summary>Task button natural width</summary>
        </key>

        <key type="b" name="animate-on-close">
            <default>true</default>
            <summary>Animate on close</summary>
        </key>

    </schema>

</schemalist>
